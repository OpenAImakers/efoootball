{
  "compilerOptions": {
    "target": "es5",
    "ignoreDeprecations": "6.0",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
        "types": ["node"]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "src/components/Advert.jsx", "src/index.js", "src/pages/Announcement/Profiles.tsx"],
  "exclude": ["node_modules"]
}